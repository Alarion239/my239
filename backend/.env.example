# ===== Required =====
DATABASE_URL=postgres://postgres:postgres@localhost:5432/my239?sslmode=disable
JWT_SECRET=change-me-in-production-this-must-be-at-least-32-chars

# ===== Optional (defaults shown) =====
PORT=8080
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# JWT settings
JWT_ISSUER=my239
JWT_AUDIENCE=api
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Rate limiter: leave empty to use in-memory; set to switch to Redis-backed.
REDIS_URL=redis://localhost:6379/0

# ===== Object storage (Yandex Object Storage) =====
# Leave S3_BUCKET empty to use the in-process MemoryStore (PDFs cannot be
# downloaded in the browser in that mode) — fine for most local work and tests.
#
# To use real storage, create a Yandex Object Storage bucket + static access
# key and set the three required vars below; the rest default to Yandex
# (endpoint storage.yandexcloud.net, region ru-central1, path-style addressing).
# Remember to apply the bucket CORS policy: backend/scripts/apply-s3-cors.sh
#
# S3_BUCKET=...
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
#
# Optional overrides (shown with defaults):
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_REGION=ru-central1
# S3_USE_PATH_STYLE=true
# S3_DOWNLOAD_TTL_MINUTES=15
# S3_UPLOAD_TTL_MINUTES=5
