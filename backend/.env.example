# ===== Required =====
DATABASE_URL=postgres://postgres:postgres@localhost:5432/my239?sslmode=disable
JWT_SECRET=change-me-in-production-this-must-be-at-least-32-chars

# ===== Optional (defaults shown) =====
PORT=8080
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# JWT settings
JWT_ISSUER=my239
JWT_AUDIENCE=api
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Rate limiter: leave empty to use in-memory; set to switch to Redis-backed.
REDIS_URL=redis://localhost:6379/0
