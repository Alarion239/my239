# ===== Required =====
DATABASE_URL=postgres://postgres:postgres@localhost:5432/my239?sslmode=disable
JWT_SECRET=change-me-in-production-this-must-be-at-least-32-chars

# ===== Optional (defaults shown) =====
PORT=8080
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# JWT settings
JWT_ISSUER=my239
JWT_AUDIENCE=api
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Rate limiter: leave empty to use in-memory; set to switch to Redis-backed.
REDIS_URL=redis://localhost:6379/0

# ===== Object storage =====
# Leave S3_BUCKET empty to use the in-process MemoryStore (PDFs cannot be
# downloaded in the browser in that mode). For dev with MinIO via
# `docker compose up -d minio minio-init`, uncomment everything below — the
# backend will then talk to MinIO at localhost:9000 and produce presigned
# URLs the browser can also fetch from localhost:9000 (no rewrite needed
# in this mode because both ends agree on the hostname).
#
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=my239-dev
# S3_ACCESS_KEY_ID=minio
# S3_SECRET_ACCESS_KEY=minio12345
# S3_USE_PATH_STYLE=true
# S3_DOWNLOAD_TTL_MINUTES=15
# S3_UPLOAD_TTL_MINUTES=5
#
# In prod (Yandex), only the bucket + creds are required; defaults handle
# the rest:
#   S3_BUCKET=...
#   S3_ACCESS_KEY_ID=...
#   S3_SECRET_ACCESS_KEY=...
